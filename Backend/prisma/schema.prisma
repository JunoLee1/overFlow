// 발주 ERP — Prisma 스키마 (PostgreSQL)
// 멀티테넌트: 모든 테넌트 테이블은 companyId 보유, 모든 조회는 companyId로 필터.
// soft delete: deletedAt(NULL이면 살아있음).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  super_admin
  admin
  staff
  viewer
}

enum OrderStatus {
  draft       // 작성중(초안)
  pending     // 승인대기
  approved    // 발주완료(승인·전송)
  shipping    // 배송중
  delayed     // 지연
  partial     // 부분입고
  received    // 입고완료
  canceled    // 취소
}

enum ShipmentStatus {
  preparing // 배송 준비중
  shipping // 운송중
  delivered // 배송중
  delayed 
}

enum ReceiptStatus {
  normal // 정상입고
  partial // 부분입고
  canceled // 취소
}

enum CommonStatus {
  active
  inactive
}

model Company {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(100)
  bizNo     String?   @unique @map("biz_no") @db.VarChar(10)
  email     String?   @db.VarChar(255)
  phone     String?   @db.VarChar(20)
  fax       String?   @db.VarChar(20)
  plan      String    @default("basic") @db.VarChar(20)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  users      User[]
  partners   Partner[]
  items      Item[]
  warehouses Warehouse[]
  orders     PurchaseOrder[]

  @@map("company")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  companyId    String?   @map("company_id") @db.Uuid // 슈퍼어드민은 NULL
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  name         String    @db.VarChar(50)
  phone        String?   @db.VarChar(20) // 배송 지연 SMS 발송 대상
  role         Role
  createdAt    DateTime  @default(now()) @map("created_at")
  deletedAt    DateTime? @map("deleted_at")

  company        Company?        @relation(fields: [companyId], references: [id])
  createdOrders  PurchaseOrder[] @relation("OrderCreatedBy")
  approvedOrders PurchaseOrder[] @relation("OrderApprovedBy")
  receipts       Receipt[]

  @@index([companyId])
  @@map("user")
}

model Partner {
  id        String       @id @default(uuid()) @db.Uuid
  companyId String       @map("company_id") @db.Uuid
  name      String       @db.VarChar(100)
  bizNo     String?      @map("biz_no") @db.VarChar(10)
  manager   String?      @db.VarChar(50)
  phone     String?      @db.VarChar(20)
  email     String?      @db.VarChar(255)
  address   String?      @db.VarChar(255)
  status    CommonStatus @default(active)
  createdAt DateTime     @default(now()) @map("created_at")
  deletedAt DateTime?    @map("deleted_at")

  company Company         @relation(fields: [companyId], references: [id])
  orders  PurchaseOrder[]

  @@unique([companyId, bizNo])
  @@index([companyId])
  @@map("partner")
}

model Item {
  id           String    @id @default(uuid()) @db.Uuid
  companyId    String    @map("company_id") @db.Uuid
  code         String    @db.VarChar(50)
  name         String    @db.VarChar(100)
  spec         String?   @db.VarChar(100)
  unit         String    @db.VarChar(20)
  defaultPrice Decimal   @default(0) @map("default_price") @db.Decimal(13, 2)
  createdAt    DateTime  @default(now()) @map("created_at")
  deletedAt    DateTime? @map("deleted_at")

  company    Company             @relation(fields: [companyId], references: [id])
  orderItems PurchaseOrderItem[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("item")
}

model Warehouse {
  id        String       @id @default(uuid()) @db.Uuid
  companyId String       @map("company_id") @db.Uuid
  code      String       @db.VarChar(50)
  name      String       @db.VarChar(100)
  address   String?      @db.VarChar(255)
  manager   String?      @db.VarChar(50)
  phone     String?      @db.VarChar(20)
  email     String?      @db.VarChar(255)
  fax       String?      @db.VarChar(20)
  status    CommonStatus @default(active)
  createdAt DateTime     @default(now()) @map("created_at")
  deletedAt DateTime?    @map("deleted_at")

  company  Company         @relation(fields: [companyId], references: [id])
  orders   PurchaseOrder[]
  receipts Receipt[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("warehouse")
}

model PurchaseOrder {
  id          String      @id @default(uuid()) @db.Uuid
  companyId   String      @map("company_id") @db.Uuid
  poNo        String      @map("po_no") @db.VarChar(30)
  partnerId   String      @map("partner_id") @db.Uuid
  warehouseId String      @map("warehouse_id") @db.Uuid
  status      OrderStatus @default(draft)
  orderDate   DateTime    @map("order_date") @db.Date
  dueDate     DateTime?   @map("due_date") @db.Date
  createdById String      @map("created_by") @db.Uuid
  approvedById String?    @map("approved_by") @db.Uuid
  rejectReason String?    @map("reject_reason") @db.VarChar(255)
  totalAmount Decimal     @default(0) @map("total_amount") @db.Decimal(15, 2)
  createdAt   DateTime    @default(now()) @map("created_at")
  deletedAt   DateTime?   @map("deleted_at")

  company    Company             @relation(fields: [companyId], references: [id])
  partner    Partner             @relation(fields: [partnerId], references: [id])
  warehouse  Warehouse           @relation(fields: [warehouseId], references: [id])
  createdBy  User                @relation("OrderCreatedBy", fields: [createdById], references: [id])
  approvedBy User?               @relation("OrderApprovedBy", fields: [approvedById], references: [id])
  items      PurchaseOrderItem[]
  shipments  Shipment[]
  receipts   Receipt[]

  @@unique([companyId, poNo])
  @@index([companyId, status])
  @@index([companyId, warehouseId])
  @@map("purchase_order")
}

model PurchaseOrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  companyId String  @map("company_id") @db.Uuid
  poId      String  @map("po_id") @db.Uuid
  itemId    String  @map("item_id") @db.Uuid
  qty       Decimal @db.Decimal(13, 2)
  unitPrice Decimal @map("unit_price") @db.Decimal(13, 2)
  amount    Decimal @db.Decimal(15, 2)
  note      String? @db.VarChar(255)

  order        PurchaseOrder @relation(fields: [poId], references: [id])
  item         Item          @relation(fields: [itemId], references: [id])
  receiptItems ReceiptItem[]

  @@index([companyId])
  @@index([poId])
  @@map("purchase_order_item")
}

model Shipment {
  id          String         @id @default(uuid()) @db.Uuid
  companyId   String         @map("company_id") @db.Uuid
  poId        String         @map("po_id") @db.Uuid
  carrierCode String?        @map("carrier_code") @db.VarChar(20)
  trackingNo  String?        @map("tracking_no") @db.VarChar(50)
  status      ShipmentStatus @default(preparing)
  shippedAt   DateTime?      @map("shipped_at")
  eta         DateTime?      @db.Date
  createdAt   DateTime       @default(now()) @map("created_at")

  order PurchaseOrder @relation(fields: [poId], references: [id])

  @@index([companyId, status])
  @@index([poId])
  @@map("shipment")
}

model Receipt {
  id          String        @id @default(uuid()) @db.Uuid
  companyId   String        @map("company_id") @db.Uuid
  poId        String        @map("po_id") @db.Uuid
  warehouseId String        @map("warehouse_id") @db.Uuid
  receivedAt  DateTime      @map("received_at") @db.Date
  receivedById String       @map("received_by") @db.Uuid
  status      ReceiptStatus @default(normal)
  createdAt   DateTime      @default(now()) @map("created_at")
  deletedAt   DateTime?     @map("deleted_at")

  order      PurchaseOrder @relation(fields: [poId], references: [id])
  warehouse  Warehouse     @relation(fields: [warehouseId], references: [id])
  receivedBy User          @relation(fields: [receivedById], references: [id])
  items      ReceiptItem[]

  @@index([companyId, warehouseId])
  @@index([poId])
  @@map("receipt")
}

model ReceiptItem {
  id             String  @id @default(uuid()) @db.Uuid
  companyId      String  @map("company_id") @db.Uuid
  receiptId      String  @map("receipt_id") @db.Uuid
  poItemId       String  @map("po_item_id") @db.Uuid
  receivedQty    Decimal @map("received_qty") @db.Decimal(13, 2)
  damagedQty     Decimal @default(0) @map("damaged_qty") @db.Decimal(13, 2)
  mismatchReason String? @map("mismatch_reason") @db.VarChar(255)
  photoUrl       String? @map("photo_url") @db.VarChar(500)

  receipt   Receipt           @relation(fields: [receiptId], references: [id])
  orderItem PurchaseOrderItem @relation(fields: [poItemId], references: [id])

  @@index([companyId])
  @@index([receiptId])
  @@map("receipt_item")
}